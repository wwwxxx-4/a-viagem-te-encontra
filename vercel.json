{
  "version": 2,
  "builds": [
    { "src": "index.html",           "use": "@vercel/static" },
    { "src": "destinos-images.json", "use": "@vercel/static" },
    { "src": "logo-mesquita.png",    "use": "@vercel/static" },
    { "src": "aviao-fallback.jpg",   "use": "@vercel/static" },
    { "src": "api/*.js",             "use": "@vercel/node" }
  ],
  "routes": [
    {
      "src": "/destinos-images.json",
      "dest": "/destinos-images.json",
      "headers": { "cache-control": "public, max-age=86400" }
    },
    {
      "src": "/logo-mesquita.png",
      "dest": "/logo-mesquita.png",
      "headers": { "cache-control": "public, max-age=2592000" }
    },
    {
      "src": "/aviao-fallback.jpg",
      "dest": "/aviao-fallback.jpg",
      "headers": { "cache-control": "public, max-age=2592000" }
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
